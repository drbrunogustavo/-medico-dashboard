# PRAXIS — variáveis de ambiente
# Copie para .env.local e preencha com seus valores reais
# NUNCA envie .env.local para o GitHub

# ─── Supabase (obrigatório) ───────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ─── Anthropic (obrigatório) ──────────────────────────────────────────────────
ANTHROPIC_API_KEY=

# ─── Geração de imagens — mínimo 1 dos 3 ─────────────────────────────────────
OPENAI_API_KEY=
GOOGLE_AI_API_KEY=
HUGGINGFACE_TOKEN=

# ─── Stripe (obrigatório para planos pagos) ───────────────────────────────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_PRICE_STARTER=
STRIPE_PRICE_PRO=
STRIPE_PRICE_ELITE=

# ─── MedX — Ala Clínica (obrigatório para Agenda/Copiloto/Pacientes) ─────────
MEDX_API_URL=
MEDX_API_KEY=

# ─── Zapi WhatsApp (opcional) ─────────────────────────────────────────────────
ZAPI_INSTANCE_ID=
ZAPI_TOKEN=
